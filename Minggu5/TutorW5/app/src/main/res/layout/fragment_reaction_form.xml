<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4ECD8"
    android:padding="24dp"> <!-- Tema Ancient Book Parchment -->

    <TextView
        android:id="@+id/tvFormTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scribe Reaction"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#5C4A3D"
        android:fontFamily="serif"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etReactionName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Nama Reaction"
        android:textColor="#3E2723"
        android:textColorHint="#A1887F"
        android:backgroundTint="#8D6E63"
        app:layout_constraintTop_toBottomOf="@id/tvFormTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvLabelElement1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Element 1:"
        android:textColor="#5C4A3D"
        android:fontFamily="serif"
        app:layout_constraintTop_toBottomOf="@id/etReactionName"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spinnerElement1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/tvLabelElement1"
        app:layout_constraintBottom_toBottomOf="@id/tvLabelElement1"
        app:layout_constraintStart_toEndOf="@id/tvLabelElement1"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvLabelElement2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Element 2:"
        android:textColor="#5C4A3D"
        android:fontFamily="serif"
        app:layout_constraintTop_toBottomOf="@id/tvLabelElement1"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spinnerElement2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/tvLabelElement2"
        app:layout_constraintBottom_toBottomOf="@id/tvLabelElement2"
        app:layout_constraintStart_toEndOf="@id/tvLabelElement2"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etReactionDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Deskripsi (Efek dari resonansi)"
        android:textColor="#3E2723"
        android:textColorHint="#A1887F"
        android:backgroundTint="#8D6E63"
        android:lines="3"
        android:gravity="top"
        app:layout_constraintTop_toBottomOf="@id/tvLabelElement2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="8dp"
        android:text="Save"
        android:backgroundTint="#F1C40F"
        android:textColor="#3E2723"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etReactionDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnCancel" />

    <Button
        android:id="@+id/btnCancel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginStart="8dp"
        android:text="Cancel"
        android:backgroundTint="#8D6E63"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etReactionDesc"
        app:layout_constraintStart_toEndOf="@id/btnSave"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>